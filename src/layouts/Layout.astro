---
import "@styles/global.css";
import BaseHead from "@components/layout/BaseHead.astro";
import Header from "@components/layout/Header.astro";
import Footer from "@components/layout/Footer.astro";
import { DEFAULT_LOCALE, HREFLANG } from "@i18n/config";
import type { Locale } from "@i18n/config";
import type { NavItem } from "@lib/types";
import { sanityClient } from "sanity:client";

interface Props {
  title: string;
  description: string;
  lang?: Locale;
  canonical?: string;
  alternateUrls?: Partial<Record<Locale, string>>;
  ogImage?: string;
  ogType?: "website" | "article";
}

const {
  title,
  description,
  lang = DEFAULT_LOCALE,
  canonical,
  alternateUrls,
  ogImage,
  ogType,
} = Astro.props;

const NAV_PROJECTION = `{
  "items": items[]{
    "label": coalesce(labels[$lang], labels.en),
    "page": page->{ isHomepage, "slug": coalesce(translations[$lang].slug.current, translations.en.slug.current) }
  }
}`;

const { headerNav, footerNav } = await sanityClient.fetch<{
  headerNav: { items: NavItem[] } | null;
  footerNav: { items: NavItem[] } | null;
}>(
  `{
    "headerNav": *[_type == "navigation" && navId.current == "header"][0]${NAV_PROJECTION},
    "footerNav": *[_type == "navigation" && navId.current == "footer"][0]${NAV_PROJECTION}
  }`,
  { lang },
);
---

<!doctype html>
<html lang={HREFLANG[lang]}>
  <head>
    <BaseHead
      title={title}
      description={description}
      lang={lang}
      canonical={canonical}
      alternateUrls={alternateUrls}
      ogImage={ogImage}
      ogType={ogType}
    />
    <slot name="head" />
  </head>
  <body>
    <Header
      lang={lang}
      alternateUrls={alternateUrls}
      navItems={headerNav?.items ?? []}
    />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} navItems={footerNav?.items ?? []} />
    <script is:inline defer src="https://cloud.umami.is/script.js" data-website-id="6d267fb3-2235-4b00-910c-ba6378c8d786"></script>
  </body>
</html>
