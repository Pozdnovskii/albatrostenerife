---
// import { PortableText } from "astro-portabletext";
import { PortableText as PortableTextInternal } from "astro-portabletext";

import type { LegalPageData } from "@lib/types";

interface Props {
  data: LegalPageData;
}

const { data } = Astro.props;
const { heading, body } = data;
---

<section class="section bg-gray-100 lg:pt-section-sm">
  <div
    class="prose prose-headings:font-medium prose-h1:text-title prose-h2:font-sans prose-h2:mt-6 prose-h2:mb-1 prose-h2:text-xl prose-a:text-accent lg:px-0"
  >
    {heading && <h1>{heading}</h1>}
    {body && <PortableTextInternal value={body} />}
  </div>
</section>
