---
import { getContactInfo, getContactTexts } from "@lib/queries";
import { DEFAULT_LOCALE } from "@i18n/config";
import type { Locale } from "@i18n/config";
import SectionHeading from "@components/ui/SectionHeading.astro";
import AgentCard from "@components/contact/AgentCard.astro";
import ContactForm from "@components/contact/ContactForm.astro";

interface Props {
  lang?: Locale;
  level?: 1 | 2;
  title?: string;
  subtitle?: string;
  left?: boolean;
  class?: string;
  sourceName?: string;
}

const {
  lang = DEFAULT_LOCALE,
  level = 2,
  title: titleProp,
  subtitle: subtitleProp,
  left = false,
  class: cls,
  sourceName = "Contact Form",
} = Astro.props;

const [contact, texts] = await Promise.all([
  getContactInfo(lang),
  level === 1 ? getContactTexts(lang) : Promise.resolve(null),
]);

const title = titleProp ?? texts?.title ?? "";
const subtitle = subtitleProp ?? texts?.subtitle ?? undefined;
---

<section id="contact" class:list={["section bg-white lg:pt-section-sm", cls]}>
  <div
    class:list={["flex flex-col max-md:gap-y-section md:flex-row md:gap-x-svw lg:gap-x-section-sm", !left && "lg:justify-center"]}
  >
    <div class="grow max-w-xl">
      <SectionHeading left {level} {title} {subtitle} smallMargin />
      <ContactForm lang={lang} {sourceName} />
    </div>

    {contact && <AgentCard contact={contact} level={level === 1 ? 2 : 3} />}
  </div>
</section>
