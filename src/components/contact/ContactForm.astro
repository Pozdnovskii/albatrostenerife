---
import { DEFAULT_LOCALE } from "@i18n/config";
import type { Locale } from "@i18n/config";
import { t } from "@i18n/ui";

interface Props {
  lang?: Locale;
}

const { lang = DEFAULT_LOCALE } = Astro.props;
const siteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;

const inputClass =
  "w-full px-4 py-3 border border-gray-200 rounded-lg bg-white text-black placeholder:text-gray-400";
---

<form
  id="contact-form"
  method="POST"
  action="/api/contact"
  class="grid grid-cols-1 gap-y-5 sm:max-md:grid-cols-2 sm:gap-x-4 lg:grid-cols-2"
>
  <input type="hidden" name="lang" value={lang} />
  <input type="hidden" name="source" value={Astro.url.pathname} />
  <!-- honeypot -->
  <input type="text" name="_trap" tabindex="-1" autocomplete="off" aria-hidden="true" class="hidden" />

  <div>
    <label for="firstName" class="block font-bold mb-1">{t(lang, "form.firstName")}</label>
    <input type="text" id="firstName" name="firstName"
      placeholder={t(lang, "form.firstName.placeholder")} class={inputClass} />
  </div>

  <div>
    <label for="lastName" class="block font-bold mb-1">{t(lang, "form.lastName")}</label>
    <input type="text" id="lastName" name="lastName"
      placeholder={t(lang, "form.lastName.placeholder")} class={inputClass} />
  </div>

  <div>
    <label for="email" class="block font-bold mb-1">{t(lang, "form.email")}</label>
    <input type="email" id="email" name="email" required
      placeholder={t(lang, "form.email.placeholder")} class={inputClass} />
  </div>

  <div>
    <label for="phone" class="block font-bold mb-1">{t(lang, "form.phone")}</label>
    <input type="tel" id="phone" name="phone"
      placeholder={t(lang, "form.phone.placeholder")} class={inputClass} />
  </div>

  <div class="sm:max-md:col-span-2 lg:col-span-2">
    <label for="message" class="block font-bold mb-1">{t(lang, "form.message")}</label>
    <textarea id="message" name="message" rows="5"
      placeholder={t(lang, "form.message.placeholder")}
      class={`${inputClass} resize-y`}></textarea>
  </div>

  <!-- Turnstile widget (invisible if siteKey not set in dev) -->
  {siteKey && (
    <div class="sm:max-md:col-span-2 lg:col-span-2">
      <div class="cf-turnstile" data-sitekey={siteKey} data-theme="light"></div>
    </div>
  )}

  <!-- Status message -->
  <p id="form-status" role="status" aria-live="polite"
    class="sm:max-md:col-span-2 lg:col-span-2 text-sm hidden"></p>

  <button
    id="form-submit"
    type="submit"
    class="py-4 bg-accent text-white text-lg cursor-pointer transition-colors rounded-lg sm:max-md:col-span-2 lg:col-span-2 hover:bg-accent/85 disabled:opacity-60 disabled:cursor-not-allowed"
  >
    {t(lang, "form.submit")}
  </button>
</form>

{siteKey && (
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
)}

<script>
  const form    = document.getElementById("contact-form") as HTMLFormElement;
  const btn     = document.getElementById("form-submit") as HTMLButtonElement;
  const status  = document.getElementById("form-status") as HTMLParagraphElement;

  const MESSAGES = {
    sending: "Sending…",
    success: "Thank you! We'll get back to you shortly.",
    error:   "Something went wrong. Please try again.",
  };

  function showStatus(type: "sending" | "success" | "error") {
    status.textContent = MESSAGES[type];
    status.className = [
      "sm:max-md:col-span-2 lg:col-span-2 text-sm",
      type === "success" ? "text-green-600" : type === "error" ? "text-red-600" : "text-gray-500",
    ].join(" ");
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    btn.disabled = true;
    showStatus("sending");

    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        body: new FormData(form),
      });
      const json = (await res.json()) as { ok: boolean; error?: string };

      if (json.ok) {
        showStatus("success");
        form.reset();
        // Reset Turnstile widget if present
        if (typeof (window as any).turnstile !== "undefined") {
          (window as any).turnstile.reset();
        }
      } else {
        showStatus("error");
        btn.disabled = false;
      }
    } catch {
      showStatus("error");
      btn.disabled = false;
    }
  });
</script>
