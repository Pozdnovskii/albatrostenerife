---
import { getImage } from "astro:assets";
import { t } from "@i18n/ui";
import { DEFAULT_LOCALE } from "@i18n/config";
import type { Locale } from "@i18n/config";
import { getContactInfo } from "@lib/queries";
import desktopSrc from "@assets/sellers.webp";
import mobileSrc from "@assets/sellers-mob.webp";
import SectionHeading from "@components/ui/SectionHeading.astro";
import ResponsivePicture from "@components/ui/ResponsivePicture.astro";
import ContactForm from "@components/contact/ContactForm.astro";
import AgentCard from "@components/contact/AgentCard.astro";

interface Props {
  lang?: Locale;
}

const { lang = DEFAULT_LOCALE } = Astro.props;

const [desktop, mobile, contact] = await Promise.all([
  getImage({
    src: desktopSrc,
    widths: [1024, 1440, 1920],
    sizes: "100vw",
    format: "webp",
  }),
  getImage({
    src: mobileSrc,
    widths: [390, 640, 828],
    sizes: "100vw",
    format: "webp",
  }),
  getContactInfo(lang),
]);
---

<section class="section relative overflow-hidden min-h-fit lg:py-section-sm">
  <div
    class="flex flex-col items-center justify-center gap-6
     md:flex-row md:items-stretch lg:gap-12"
  >
    <div class="w-full max-w-2xl rounded-lg bg-white p-4 md:p-10">
      <SectionHeading
        left
        level={1}
        title={t(lang, "sellers.title")}
        subtitle={t(lang, "sellers.subtitle")}
        subtitlePlain
        subtitleClass="text-black"
        smallMargin
        small
      />
      <ContactForm lang={lang} showAptNo sourceName={t(DEFAULT_LOCALE, "sellers.title")} />
    </div>

    <!-- Agent card -->
    {
      contact && (
        <AgentCard
          {contact}
          level={2}
          class="order-last rounded-lg bg-white p-4 md:p-6 "
        />
      )
    }
  </div>

  <ResponsivePicture
    {desktop}
    {mobile}
    width={mobileSrc.width}
    height={mobileSrc.height}
  />
</section>
