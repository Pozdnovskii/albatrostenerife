---
interface Props {
  direction: "prev" | "next";
  controls: string;
  label: string;
  class?: string;
  [key: string]: unknown;
}

const { direction, controls, label, class: className, ...rest } = Astro.props;
---

<button
  {...rest}
  aria-controls={controls}
  aria-label={label}
  class:list={[
    "absolute w-[48px] aspect-square  flex items-center justify-center cursor-pointer",
    direction === "prev" && "rotate-180",
    className,
  ]}
>
  <svg
    aria-hidden="true"
    class="w-3/4 aspect-square rounded-md transition-colors"
    ><use href="#icon-arrow"></use></svg
  >
</button>
