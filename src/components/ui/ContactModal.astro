---
import type { Locale } from "@i18n/config";
import { DEFAULT_LOCALE } from "@i18n/config";
import ContactForm from "@components/contact/ContactForm.astro";

interface Props {
  lang?: Locale;
  showAptNo?: boolean;
  sourceName?: string;
  messagePlaceholder?: string | null;
  submitText?: string | null;
}

const { lang = DEFAULT_LOCALE, showAptNo = false, sourceName, messagePlaceholder, submitText } = Astro.props;
---

<dialog
  id="contact-modal"
  class="m-auto w-full max-w-xl rounded-2xl bg-white p-8 shadow-2xl backdrop:bg-black/60 open:flex open:flex-col"
>
  <button
    id="contact-modal-close"
    type="button"
    aria-label="Close"
    class="ml-auto mb-4 text-gray-400 hover:text-black transition-colors text-2xl leading-none cursor-pointer"
  >
    ✕
  </button>
  <ContactForm {lang} {showAptNo} {sourceName} {messagePlaceholder} {submitText} />
</dialog>

<script>
  const modal = document.getElementById("contact-modal") as HTMLDialogElement;
  const closeBtn = document.getElementById("contact-modal-close");

  // Open via any element with data-open-modal
  document.addEventListener("click", (e) => {
    if ((e.target as HTMLElement).closest("[data-open-modal]")) {
      modal?.showModal();
    }
  });

  // Close button
  closeBtn?.addEventListener("click", () => modal?.close());

  // Click on backdrop closes
  modal?.addEventListener("click", (e) => {
    if (e.target === modal) modal.close();
  });
</script>
