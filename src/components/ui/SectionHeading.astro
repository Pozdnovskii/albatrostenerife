---
interface Props {
  title: string;
  subtitle?: string;
  /** Heading level. Default: 2 */
  level?: 1 | 2 | 3;
  /** Left-align instead of center */
  left?: boolean;
  /** Full Tailwind class for title color. E.g. "text-white", "text-black", "text-accent" */
  titleClass?: string;
  /** Full Tailwind class for subtitle color. Default: "text-accent" */
  subtitleClass?: string;
  /** Skip uppercase + tracking on subtitle (for paragraph-length subtitles) */
  subtitlePlain?: boolean;
  /** Larger title size (text-title-big) */
  big?: boolean;
  /** Smaller title size (text-title-sm) + compact margins */
  small?: boolean;
  /** Compact margins only, without affecting font size */
  smallMargin?: boolean;
  class?: string;
}

const {
  title,
  subtitle,
  level = 2,
  left = false,
  titleClass,
  subtitleClass = "text-accent",
  subtitlePlain = false,
  big = false,
  small = false,
  smallMargin = false,
  class: cls,
} = Astro.props;

const Tag = `h${level}` as "h1" | "h2" | "h3";
---

<hgroup
  class:list={[
    left ? "text-left" : "text-center",
    small || smallMargin ? "mb-section-xs" : "mb-section-sm",
    "text-balance",
    cls,
  ]}
>
  <Tag
    class:list={[
      big ? "text-title-big" : small ? "text-title-sm" : "text-title",
      titleClass,
      "leading-none",
      !subtitle ? "mb-0" : small || smallMargin ? "mb-[.2em]" : "mb-[.33em]",
    ]}
  >
    {title}
  </Tag>
  {
    subtitle && (
      <p
        class:list={[
          big ? "text-lg lg:text-xl" : small ? "text-sm" : "text-base",
          !subtitlePlain && "uppercase tracking-[0.42em] font-light",

          subtitleClass,
        ]}
      >
        {subtitle}
      </p>
    )
  }
</hgroup>
