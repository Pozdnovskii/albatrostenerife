---
import type { Locale } from "@i18n/config";
import { t } from "@i18n/ui";

interface Props {
  url: string;
  title: string;
  lang: Locale;
  class?: string;
}

const { url, title, lang, class: className = "" } = Astro.props;

const text = `${title} — ${url}`;
const links = {
  whatsapp: `https://wa.me/?text=${encodeURIComponent(text)}`,
  telegram: `https://t.me/share/url?url=${encodeURIComponent(url)}&text=${encodeURIComponent(title)}`,
  facebook: `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`,
  email: `mailto:?subject=${encodeURIComponent(title)}&body=${encodeURIComponent(text)}`,
};

const iconClass = "w-[24px] aspect-square";
const linkClass =
  "inline-flex items-center justify-center w-[44px] aspect-square rounded-full text-gray-700 hover:text-accent hover:bg-gray-100 transition-colors";
---

<ul class:list={["flex flex-wrap items-center -translate-x-[10px]", className]}>
  <li>
    <a
      href={links.whatsapp}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={t(lang, "share.whatsapp")}
      title={t(lang, "share.whatsapp")}
      class={linkClass}
    >
      <svg
        class={iconClass}
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          d="M19.05 4.91A10 10 0 0 0 12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.9 9.9 0 0 0 4.74 1.21h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.91-7.01zM12.05 20.15h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.04-.2-.31a8.21 8.21 0 0 1-1.26-4.37c0-4.54 3.7-8.24 8.24-8.24a8.2 8.2 0 0 1 5.83 2.41 8.2 8.2 0 0 1 2.41 5.84c0 4.54-3.7 8.24-8.24 8.24zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.12-.16.25-.64.81-.78.97-.14.16-.29.18-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.02-.38.11-.5.11-.11.25-.29.37-.43.12-.14.16-.25.25-.41.08-.16.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.4-.42-.56-.42-.14 0-.31-.02-.47-.02-.16 0-.43.06-.66.31-.23.25-.86.84-.86 2.05 0 1.21.88 2.38 1 2.54.12.16 1.74 2.66 4.22 3.73.59.26 1.05.41 1.41.52.59.19 1.13.16 1.55.1.47-.07 1.47-.6 1.68-1.18.21-.58.21-1.08.14-1.18-.06-.1-.23-.16-.48-.28z"
        ></path>
      </svg>
    </a>
  </li>

  <li>
    <a
      href={links.telegram}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={t(lang, "share.telegram")}
      title={t(lang, "share.telegram")}
      class={linkClass}
    >
      <svg
        class={iconClass}
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          d="M9.78 18.65l.28-4.23 7.68-6.92c.34-.31-.07-.46-.52-.19L7.74 13.3 3.64 12c-.88-.25-.89-.86.2-1.3l15.97-6.16c.73-.33 1.43.18 1.15 1.3l-2.72 12.81c-.19.91-.74 1.13-1.5.71L12.6 16.3l-1.99 1.93c-.23.23-.42.42-.83.42z"
        ></path>
      </svg>
    </a>
  </li>

  <li>
    <a
      href={links.facebook}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={t(lang, "share.facebook")}
      title={t(lang, "share.facebook")}
      class={linkClass}
    >
      <svg
        class={iconClass}
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.99 3.66 9.13 8.44 9.88V14.9H7.9V12h2.54V9.8c0-2.51 1.49-3.89 3.78-3.89 1.09 0 2.23.2 2.23.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.77l-.44 2.9h-2.33v6.98C18.34 21.13 22 16.99 22 12z"
        ></path>
      </svg>
    </a>
  </li>

  <li>
    <a
      href={links.email}
      aria-label={t(lang, "share.email")}
      title={t(lang, "share.email")}
      class={linkClass}
    >
      <svg
        class={iconClass}
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <rect x="3" y="5" width="18" height="14" rx="2"></rect>
        <path d="m3 7 9 6 9-6"></path>
      </svg>
    </a>
  </li>

  <li>
    <button
      type="button"
      data-share-copy
      data-url={url}
      data-copied-label={t(lang, "share.copied")}
      aria-label={t(lang, "share.copy")}
      title={t(lang, "share.copy")}
      class={`${linkClass} cursor-pointer relative`}
    >
      <svg
        data-icon-copy
        class={iconClass}
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <rect x="9" y="9" width="11" height="11" rx="2"></rect>
        <path d="M5 15V5a2 2 0 0 1 2-2h10"></path>
      </svg>
      <svg
        data-icon-done
        class={`${iconClass} hidden text-green-600`}
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="m5 12 5 5 9-11"></path>
      </svg>
      <span
        data-share-toast
        class="hidden absolute -top-8 left-1/2 -translate-x-1/2 text-xs bg-gray-900 text-white px-2 py-1 rounded whitespace-nowrap pointer-events-none"
      ></span>
    </button>
  </li>
</ul>

<script>
  document
    .querySelectorAll<HTMLButtonElement>("[data-share-copy]")
    .forEach((btn) => {
      const url = btn.dataset.url ?? "";
      const copiedLabel = btn.dataset.copiedLabel ?? "Copied";
      const copyIcon = btn.querySelector<SVGElement>("[data-icon-copy]")!;
      const doneIcon = btn.querySelector<SVGElement>("[data-icon-done]")!;
      const toast = btn.querySelector<HTMLElement>("[data-share-toast]")!;
      let timer: number | undefined;

      btn.addEventListener("click", async () => {
        try {
          if (navigator.clipboard) {
            await navigator.clipboard.writeText(url);
          } else {
            const ta = document.createElement("textarea");
            ta.value = url;
            ta.style.position = "fixed";
            ta.style.opacity = "0";
            document.body.appendChild(ta);
            ta.select();
            document.execCommand("copy");
            document.body.removeChild(ta);
          }
          copyIcon.classList.add("hidden");
          doneIcon.classList.remove("hidden");
          toast.textContent = copiedLabel;
          toast.classList.remove("hidden");
          clearTimeout(timer);
          timer = window.setTimeout(() => {
            copyIcon.classList.remove("hidden");
            doneIcon.classList.add("hidden");
            toast.classList.add("hidden");
          }, 1500);
        } catch {}
      });
    });
</script>
