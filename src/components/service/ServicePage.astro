---
import type { Locale } from "@i18n/config";
import type { ServicePageData } from "@lib/types";
import { getContactInfo, getContactPageSlug } from "@lib/queries";
import { localePrefix } from "@i18n/utils";
import { serviceSchema } from "@lib/schema";
import SchemaOrg from "@components/seo/SchemaOrg.astro";
import ServiceHero from "./ServiceHero.astro";
import ServiceContent from "./ServiceContent.astro";
import ServiceAgent from "./ServiceAgent.astro";
import ContactModal from "@components/ui/ContactModal.astro";

interface Props {
  service: ServicePageData;
  lang: Locale;
}

const { service, lang } = Astro.props;
const [contact, contactSlug] = await Promise.all([
  getContactInfo(lang),
  getContactPageSlug(lang),
]);
const contactEmailHref = contactSlug ? `${localePrefix(lang)}/${contactSlug}` : undefined;

const origin = Astro.url.origin;
const prefix = localePrefix(lang);
const pageUrl = String(Astro.url);
const breadcrumbs = [
  { name: "Home", url: `${origin}${prefix}` },
  { name: service.title, url: pageUrl },
];
---

<SchemaOrg schema={serviceSchema(service.title, service.metaDescription, pageUrl, lang, breadcrumbs)} />

<ServiceHero {service} {lang} />
<ServiceContent {service} />
{contact && service.agentQuote && (
  <ServiceAgent agentQuote={service.agentQuote} {contact} emailHref={contactEmailHref} />
)}
<ContactModal {lang} showAptNo />
