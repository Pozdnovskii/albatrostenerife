---
import type { Locale } from "@i18n/config";
import type { ServicePageData, ServiceCard as ServiceCardData } from "@lib/types";
import { getContactInfo, getContactPageSlug } from "@lib/queries";
import { localePrefix } from "@i18n/utils";
import { t } from "@i18n/ui";
import { serviceSchema } from "@lib/schema";
import SchemaOrg from "@components/seo/SchemaOrg.astro";
import SectionHeading from "@components/ui/SectionHeading.astro";
import ServiceHero from "./ServiceHero.astro";
import ServiceContent from "./ServiceContent.astro";
import ServiceAgent from "./ServiceAgent.astro";
import ServiceCard from "./ServiceCard.astro";
import ContactModal from "@components/ui/ContactModal.astro";

interface Props {
  service: ServicePageData;
  lang: Locale;
  otherServices?: ServiceCardData[];
}

const { service, lang, otherServices = [] } = Astro.props;
const [contact, contactSlug] = await Promise.all([
  getContactInfo(lang),
  getContactPageSlug(lang),
]);
const contactEmailHref = contactSlug ? `${localePrefix(lang)}/${contactSlug}` : undefined;

const origin = Astro.url.origin;
const prefix = localePrefix(lang);
const pageUrl = String(Astro.url);
const breadcrumbs = [
  { name: "Home", url: `${origin}${prefix}` },
  { name: service.title, url: pageUrl },
];
---

<SchemaOrg schema={serviceSchema(service.title, service.metaDescription, pageUrl, lang, breadcrumbs)} />

<ServiceHero {service} {lang} />
<ServiceContent {service} />
{contact && service.agentQuote && (
  <ServiceAgent agentQuote={service.agentQuote} {contact} emailHref={contactEmailHref} />
)}
{otherServices.length > 0 && (
  <section class="section bg-gray-100">
    <div>
      <SectionHeading title={t(lang, "service.otherServices")} level={2} left smallMargin />
      <ul class="grid grid-cols-1 gap-y-section-sm sm:grid-cols-3 sm:gap-x-6">
        {otherServices.map(s => (
          <li>
            <ServiceCard service={s} href={`${prefix}/${s.slug}`} />
          </li>
        ))}
      </ul>
    </div>
  </section>
)}
<ContactModal {lang} showAptNo sourceName={service.enTitle ?? service.title} messagePlaceholder={service.formMessagePlaceholder} submitText={service.formSubmitText} />
