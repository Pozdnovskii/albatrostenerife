---
import { getImage } from "astro:assets";
import type { Locale } from "@i18n/config";
import type { ServicePageData } from "@lib/types";
import { t } from "@i18n/ui";
import SectionHeading from "@components/ui/SectionHeading.astro";
import ResponsivePicture from "@components/ui/ResponsivePicture.astro";

interface Props {
  service: ServicePageData;
  lang: Locale;
}

const { service, lang } = Astro.props;

// Process images only if both are uploaded in Sanity Studio.
// getImage() runs at build time — Sharp optimizes and generates srcset.
// Desktop: 1920×960 (2:1), mobile: 1000×1250 (4:5) as uploaded.
const hasImages = !!service.imageDesktop && !!service.imageMobile;

const [desktop, mobile] = hasImages
  ? await Promise.all([
      getImage({
        src: service.imageDesktop!.url,
        width: service.imageDesktop!.width,
        height: service.imageDesktop!.height,
        widths: [768, 1024, 1440, 1920],
        sizes: "100vw",
        format: "webp",
      }),
      getImage({
        src: service.imageMobile!.url,
        width: service.imageMobile!.width,
        height: service.imageMobile!.height,
        widths: [390, 640, 828, 1000],
        sizes: "100vw",
        format: "webp",
      }),
    ])
  : [null, null];
---

<!-- Shorter than homepage hero (min-h-svh → min-h-[60svh]) since service pages
     have content sections below. At 2xl the 2:1 desktop image drives the height. -->
<section
  id="hero"
  class="section relative min-h-fit aspect-4/5 md:aspect-2/1 2xl:min-h-200"
>
  <div class="flex flex-col items-center justify-center gap-6">
    <SectionHeading
      title={service.title}
      subtitle={t(lang, "service.heroSubtitle")}
      level={1}
      big
      subtitleClass="text-inherit"
    />

    {
      desktop && mobile && (
        <ResponsivePicture
          {desktop}
          {mobile}
          width={service.imageMobile!.width}
          height={service.imageMobile!.height}
        />
      )
    }
  </div>
</section>
