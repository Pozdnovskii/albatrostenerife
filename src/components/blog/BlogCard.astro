---
import { Image } from "astro:assets";
import type { Post } from "@lib/types";
import HeadingSmall from "@components/ui/HeadingSmall.astro";

interface Props {
  post: Post;
  href: string;
  level?: 2 | 3;
}

const { post, href, level = 3 } = Astro.props;

const d = new Date(post.publishedAt);
const date = `${String(d.getDate()).padStart(2, "0")}.${String(d.getMonth() + 1).padStart(2, "0")}.${d.getFullYear()}`;
const tag = post.tags?.[0] ?? null;
---

<article
  class="relative h-full flex flex-col-reverse bg-white rounded-xl overflow-clip shadow-sm group"
>
  <div class="flex flex-col flex-1 py-5 px-svw lg:px-5">
    <HeadingSmall {level} class="line-clamp-2 mb-6">
      <a
        href={href}
        class="after:absolute after:inset-0 hover:text-accent transition-colors"
      >
        {post.title}
      </a>
    </HeadingSmall>

    <div
      class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-gray-600 mb-1.5 mt-auto"
    >
      <span class="flex items-center gap-1">
        <svg class="w-3 aspect-square shrink-0" aria-hidden="true">
          <use href="#icon-calendar"></use>
        </svg>
        <time datetime={post.publishedAt}>{date}</time>
      </span>
      {
        tag && (
          <span class="flex items-center gap-1.5">
            <svg class="w-3.5 aspect-square shrink-0" aria-hidden="true">
              <use href="#icon-tag" />
            </svg>
            {tag.name}
          </span>
        )
      }
    </div>

    {
      post.description && (
        <p class=" text-gray-800 line-clamp-3">{post.description}</p>
      )
    }
  </div>

  {
    post.mainImage && (
      <div class="aspect-4/3 overflow-clip bg-gray-100 shrink-0 pointer-events-none">
        <Image
          src={post.mainImage}
          alt={post.mainImageAlt ?? post.title}
          width={640}
          height={480}
          loading="lazy"
          sizes="(min-width: 1024px) calc(33vw - 24px), (min-width: 640px) calc(50vw - 24px), 100vw"
          class="w-full h-full object-cover transition-transform duration-500 group-has-[a:hover]:scale-105"
        />
      </div>
    )
  }
</article>
