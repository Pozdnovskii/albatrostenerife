---
import { Image } from "astro:assets";
import type { Post } from "@lib/types";
import type { Locale } from "@i18n/config";
import { t } from "@i18n/ui";
import { localePrefix } from "@i18n/utils";
import { blogPostSchema } from "@lib/schema";
import SchemaOrg from "@components/seo/SchemaOrg.astro";
import SectionHeading from "@components/ui/SectionHeading.astro";
import BlogList from "@components/blog/BlogList.astro";
import PostBody from "@components/blog/PostBody.astro";
import ContactSection from "@components/contact/ContactSection.astro";
import PostCta from "@components/blog/PostCta.astro";
import { getContactInfo } from "@lib/queries";
import advisorPhoto from "@assets/ivan_uher.webp";

interface Props {
  post: Post;
  lang: Locale;
  relatedPosts: Post[];
  blogSlug: string;
}

const { post, lang, relatedPosts, blogSlug } = Astro.props;
const contact = post.ctaTitle ? await getContactInfo(lang) : null;
const origin = Astro.url.origin;
const prefix = localePrefix(lang);
const blogUrl = `${origin}${prefix}/${blogSlug}`;
const pageUrl = String(Astro.url);
const breadcrumbs = [
  { name: "Home", url: origin },
  { name: t(lang, "blog.pageTitle"), url: blogUrl },
  { name: post.title, url: pageUrl },
];

const d = new Date(post.publishedAt);
const date = `${String(d.getDate()).padStart(2, "0")}.${String(d.getMonth() + 1).padStart(2, "0")}.${d.getFullYear()}`;
---

<SchemaOrg schema={blogPostSchema(post, pageUrl, lang, breadcrumbs)} />

<section class="section bg-white pt-section-sm pb-10">
  <div class="max-w-5xl">
    <SectionHeading
      title={post.title}
      level={1}
      left
      smallMargin
      subtitle={post.description ?? undefined}
      subtitlePlain
      subtitleClass="text-black/80 max-w-prose"
    />

    {
      post.mainImage && (
        <Image
          src={post.mainImage}
          alt={post.mainImageAlt ?? post.title}
          width={940}
          height={529}
          loading="eager"
          class="w-full rounded-xl overflow-hidden aspect-video mb-6"
        />
      )
    }

    <div
      class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-gray-700"
    >
      <span class="flex items-center gap-2">
        <Image
          src={advisorPhoto}
          alt="Ivan Uher"
          width={28}
          height={28}
          class="rounded-full object-cover w-7 aspect-square"
          loading="eager"
        />
        <span>Ivan Uher</span>
      </span>

      <span class="flex items-center gap-1.5">
        <svg class="w-3 aspect-square shrink-0" aria-hidden="true">
          <use href="#icon-calendar"></use>
        </svg>
        <time datetime={post.publishedAt}>{date}</time>
      </span>
      {
        post.tags.map((tag) => (
          <span class="flex items-center gap-1.5">
            <svg class="w-3.5 aspect-square shrink-0" aria-hidden="true">
              <use href="#icon-tag" />
            </svg>
            <span>{tag.name}</span>
          </span>
        ))
      }
    </div>
  </div>
</section>

{
  post.body && post.body.length > 0 && (
    <section class="section bg-white pt-0 pb-section-xs">
      <div class="max-w-5xl prose prose-a:text-accent">
        <PostBody body={post.body} {lang} {blogSlug} />
        {post.faq && post.faq.length > 0 && (
          <section>
            <h2>FAQ</h2>
            <dl class="not-prose">
            {post.faq.map((item) => (
                <dt class="font-medium text-lg mb-1">
                  {item.question}
                </dt>
                <dd class="mb-6">{item.answer}</dd>

            ))}
          </dl>
          </section>
        )}
      </div>
    </section>
  )
}

{post.ctaTitle
  ? <PostCta {post} {lang} {contact} {blogSlug} />
  : <ContactSection {lang} left class="[&>div]:max-w-5xl" sourceName={`Blog: ${post.enTitle ?? post.title}`} />
}

{
  relatedPosts.length > 0 && (
    <section class="section bg-gray-100">
      <div>
        <SectionHeading
          title={t(lang, "blog.relatedPosts")}
          level={2}
          left
          smallMargin
        />
        <BlogList posts={relatedPosts} {lang} {blogSlug} />
      </div>
    </section>
  )
}
