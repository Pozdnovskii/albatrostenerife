---
import { Image } from "astro:assets";
import type { Locale } from "@i18n/config";
import { localePrefix } from "@i18n/utils";

// ── Types ─────────────────────────────────────────────────────────────────────

type InternalRef = {
  _type: "blogPost" | "service" | "seoSettings";
  isHomepage: boolean;
  slug: string | null;
} | null;

type PTLink = {
  _key: string;
  _type: "link";
  href?: string;
  blank?: boolean;
  internalRef?: InternalRef;
};
type PTSpan = { _key: string; _type: "span"; text: string; marks: string[] };

type TextBlock = {
  _key: string;
  _type: "block";
  style: "normal" | "h2" | "h3" | "h4" | "blockquote";
  listItem?: "bullet" | "number";
  children: PTSpan[];
  markDefs: PTLink[];
};

type ImageBlock = {
  _key: string;
  _type: "image";
  asset: { url: string };
  alt?: string;
  caption?: string;
};

type Block = TextBlock | ImageBlock;

type TextChunk  = { kind: "block"; block: TextBlock };
type ImageChunk = { kind: "image"; block: ImageBlock };
type ListChunk  = { kind: "list"; listItem: "bullet" | "number"; items: TextBlock[] };
type Chunk = TextChunk | ImageChunk | ListChunk;

interface Props {
  body: unknown[];
  lang: Locale;
  blogSlug: string;
}

const { body, lang, blogSlug } = Astro.props;
const prefix = localePrefix(lang);

// ── Inline HTML builder ────────────────────────────────────────────────────────

function resolveHref(link: PTLink): string {
  const ref = link.internalRef;
  if (ref) {
    if (ref.isHomepage) return `${prefix}/`;
    if (ref._type === "blogPost") return `${prefix}/${blogSlug}/${ref.slug ?? ""}`;
    // service or seoSettings — slug is the full path segment
    return `${prefix}/${ref.slug ?? ""}`;
  }
  return link.href ?? "#";
}

function inlineHTML(children: PTSpan[], markDefs: PTLink[]): string {
  return children
    .map((span) => {
      let html = span.text
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;");

      for (const mark of span.marks) {
        const link = markDefs.find((m) => m._key === mark);
        if (link) {
          const href = resolveHref(link);
          const extras = link.blank ? ' target="_blank" rel="noopener noreferrer"' : "";
          html = `<a href="${href}"${extras} class="text-accent underline hover:no-underline transition-colors">${html}</a>`;
        } else if (mark === "strong")        html = `<strong class="font-semibold">${html}</strong>`;
        else if (mark === "em")              html = `<em>${html}</em>`;
        else if (mark === "underline")       html = `<u>${html}</u>`;
        else if (mark === "strike-through")  html = `<s>${html}</s>`;
      }

      return html;
    })
    .join("");
}

// ── Group consecutive list items ───────────────────────────────────────────────

const chunks: Chunk[] = [];

for (const raw of body as Block[]) {
  if (raw._type === "image") {
    chunks.push({ kind: "image", block: raw });
  } else if (raw._type === "block" && raw.listItem) {
    const last = chunks.at(-1);
    if (last?.kind === "list" && last.listItem === raw.listItem) {
      last.items.push(raw);
    } else {
      chunks.push({ kind: "list", listItem: raw.listItem, items: [raw] });
    }
  } else if (raw._type === "block") {
    chunks.push({ kind: "block", block: raw });
  }
}
---

<div class="max-w-2xl">
  {chunks.map((chunk) => {
    // Image
    if (chunk.kind === "image") {
      const { block } = chunk;
      return (
        <figure class="my-8">
          <Image
            src={block.asset.url}
            alt={block.alt ?? ""}
            width={900}
            height={600}
            loading="lazy"
            class="w-full rounded-xl"
          />
          {block.caption && (
            <figcaption class="mt-2 text-sm text-center text-gray-500">{block.caption}</figcaption>
          )}
        </figure>
      );
    }

    // List
    if (chunk.kind === "list") {
      const Tag = chunk.listItem === "bullet" ? "ul" : "ol";
      return (
        <Tag class:list={["my-4 pl-5 space-y-1", chunk.listItem === "bullet" ? "list-disc" : "list-decimal"]}>
          {chunk.items.map((item) => (
            <li
              class="leading-relaxed text-gray-800"
              set:html={inlineHTML(item.children, item.markDefs)}
            />
          ))}
        </Tag>
      );
    }

    // Text block
    const { block } = chunk;
    const html = inlineHTML(block.children, block.markDefs);

    if (block.style === "h2")
      return <h2 class="text-2xl font-semibold mt-10 mb-3 text-gray-900" set:html={html} />;
    if (block.style === "h3")
      return <h3 class="text-xl font-semibold mt-8 mb-2 text-gray-900" set:html={html} />;
    if (block.style === "h4")
      return <h4 class="text-lg font-semibold mt-6 mb-2 text-gray-900" set:html={html} />;
    if (block.style === "blockquote")
      return (
        <blockquote
          class="my-6 pl-5 border-l-4 border-accent italic text-gray-600 leading-relaxed"
          set:html={html}
        />
      );

    return <p class="mb-4 leading-relaxed text-gray-800" set:html={html} />;
  })}
</div>
