---
import type { Locale } from "@i18n/config";
import { DEFAULT_LOCALE } from "@i18n/config";
import { t } from "@i18n/ui";
import { getPosts, getBlogSlugs } from "@lib/queries";
import { localePrefix } from "@i18n/utils";
import { collectionSchema } from "@lib/schema";
import SectionHeading from "@components/ui/SectionHeading.astro";
import BlogList from "@components/blog/BlogList.astro";
import SchemaOrg from "@components/seo/SchemaOrg.astro";
import ContactSection from "@components/contact/ContactSection.astro";

interface Props {
  lang?: Locale;
  tagId?: string;
  title?: string;
  breadcrumbs?: { name: string; url?: string }[];
}

const { lang = DEFAULT_LOCALE, tagId, title, breadcrumbs } = Astro.props;
const [posts, blogSlugs] = await Promise.all([
  getPosts(lang, undefined, undefined, tagId),
  getBlogSlugs(),
]);
const blogSlug = blogSlugs[lang] ?? "blog";
const origin = Astro.url.origin;
const blogUrl = `${origin}${localePrefix(lang)}/${blogSlug}`;
const itemUrls = posts.map((p) => `${blogUrl}/${p.slug}`);
const heading = title ?? t(lang, "blog.pageTitle");
---

{
  !tagId && (
    <SchemaOrg schema={collectionSchema(heading, blogUrl, lang, itemUrls)} />
  )
}

<section class="section bg-gray-100 lg:pt-section-sm">
  <div>
    <SectionHeading
      big
      smallMargin
      title={heading}
      subtitle={tagId ? undefined : t(lang, "blog.pageSubtitle")}
      level={1}
    />

    <BlogList {posts} {lang} {blogSlug} level={2} />
  </div>
</section>

<ContactSection {lang} sourceName={tagId ? `Blog tag: ${heading}` : "Blog"} />
