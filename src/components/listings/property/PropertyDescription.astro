---
import type { PTBlock } from "@lib/types";
import type { Locale } from "@i18n/config";
import { getListingsTexts } from "@lib/queries";
import PropertySection from "@components/listings/ui/PropertySection.astro";

interface Props {
  description: PTBlock[];
  lang: Locale;
}

const { description, lang } = Astro.props;
const texts = await getListingsTexts(lang);
---

<PropertySection title={texts?.description ?? ""}>
  <div
    data-desc-wrapper
    class="relative after:absolute after:bottom-0 after:inset-x-0 after:h-16 after:bg-linear-to-t after:from-white after:to-transparent after:pointer-events-none data-[expanded]:after:hidden"
  >
    <div
      id="desc-body"
      data-desc-body
      class="overflow-hidden max-h-64 transition-[max-height] duration-500"
    >
      {(() => {
        const nodes: any[] = [];
        let i = 0;
        while (i < description.length) {
          const block = description[i];
          if (block.listItem === "bullet" || block.listItem === "number") {
            const tag = block.listItem === "bullet" ? "ul" : "ol";
            const items: any[] = [];
            while (i < description.length && description[i].listItem === block.listItem) {
              const b = description[i];
              items.push(
                <li class="mb-1">
                  {b.children.map((span) =>
                    span.marks.includes("strong")
                      ? <strong class="font-semibold">{span.text}</strong>
                      : span.text
                  )}
                </li>
              );
              i++;
            }
            nodes.push(
              tag === "ul"
                ? <ul class="list-disc list-outside pl-5 mb-4 text-gray-800 space-y-0.5">{items}</ul>
                : <ol class="list-decimal list-outside pl-5 mb-4 text-gray-800 space-y-0.5">{items}</ol>
            );
          } else {
            nodes.push(
              <p class="mb-4 leading-relaxed text-gray-800">
                {block.children.map((span) =>
                  span.marks.includes("strong")
                    ? <strong class="font-semibold">{span.text}</strong>
                    : span.text
                )}
              </p>
            );
            i++;
          }
        }
        return nodes;
      })()}
    </div>
  </div>
  <button
    data-desc-btn
    aria-expanded="false"
    aria-controls="desc-body"
    class="mt-3 text-sm text-gray-500 hover:text-gray-800 transition-colors cursor-pointer"
  >
    <span data-more>{texts?.readMore ?? ""}</span>
    <span data-less class="hidden">{texts?.readLess ?? ""}</span>
  </button>
</PropertySection>

<script>
  document.querySelectorAll<HTMLElement>("[data-desc-btn]").forEach((btn) => {
    const wrapper = btn.previousElementSibling as HTMLElement;
    const body = wrapper.querySelector<HTMLElement>("[data-desc-body]")!;
    const more = btn.querySelector<HTMLElement>("[data-more]")!;
    const less = btn.querySelector<HTMLElement>("[data-less]")!;

    if (body.scrollHeight <= 256) {
      btn.hidden = true;
      wrapper.dataset.expanded = "";
      body.style.maxHeight = "none";
      return;
    }

    let expanded = false;
    btn.addEventListener("click", () => {
      expanded = !expanded;
      body.style.maxHeight = expanded ? `${body.scrollHeight}px` : "256px";
      btn.setAttribute("aria-expanded", String(expanded));
      if (expanded) wrapper.dataset.expanded = "";
      else delete wrapper.dataset.expanded;
      more.classList.toggle("hidden", expanded);
      less.classList.toggle("hidden", !expanded);
    });
  });
</script>
