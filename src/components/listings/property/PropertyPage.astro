---
import type { Property } from "@lib/types";
import type { Locale } from "@i18n/config";
import { t } from "@i18n/ui";
import { localePrefix } from "@i18n/utils";
import { propertySchema } from "@lib/schema";
import SchemaOrg from "@components/seo/SchemaOrg.astro";
import SectionHeading from "@components/ui/SectionHeading.astro";
import PropertyList from "@components/listings/PropertyList.astro";
import PropertyFeatures from "@components/listings/property/PropertyFeatures.astro";
import PropertyDetails from "@components/listings/property/PropertyDetails.astro";
import PropertyVideo from "@components/listings/property/PropertyVideo.astro";
import PropertyVirtualTour from "@components/listings/property/PropertyVirtualTour.astro";
import PropertyDescription from "@components/listings/property/PropertyDescription.astro";
import PropertyGallery from "@components/listings/property/PropertyGallery.astro";

interface Props {
  property: Property;
  lang: Locale;
  relatedProperties: Property[];
  listingsSlug: string;
}

const { property, lang, relatedProperties, listingsSlug } = Astro.props;
const origin = Astro.url.origin;
const prefix = localePrefix(lang);
const listingsUrl = `${origin}${prefix}/${listingsSlug}`;
const pageUrl = String(Astro.url);
const breadcrumbs = [
  { name: "Home", url: origin },
  { name: t(lang, "listings.pageTitle"), url: listingsUrl },
  { name: property.title, url: pageUrl },
];
---

<SchemaOrg schema={propertySchema(property, pageUrl, breadcrumbs)} />

<section class="section bg-white lg:py-section-sm">
  <div>
    <SectionHeading title={property.title} level={1} big left smallMargin />
    <PropertyGallery images={property.images} title={property.title} {lang} />
  </div>
</section>

<PropertyDetails {property} {lang} />

{
  property.features && property.features.length > 0 && (
    <PropertyFeatures features={property.features} {lang} />
  )
}

{
  property.description && property.description.length > 0 && (
    <PropertyDescription description={property.description} {lang} />
  )
}

{property.videoUrl && <PropertyVideo url={property.videoUrl} {lang} />}

{
  property.virtualTourUrl && (
    <PropertyVirtualTour url={property.virtualTourUrl} {lang} />
  )
}

{
  relatedProperties.length > 0 && (
    <section class="section bg-gray-100">
      <div>
        <SectionHeading
          title={t(lang, "listings.otherProperties")}
          level={2}
          left
          smallMargin
        />
        <PropertyList properties={relatedProperties} {lang} {listingsSlug} />
      </div>
    </section>
  )
}
