---
import type { Locale } from "@i18n/config";
import type { Review } from "@lib/types";
import HeroSection from "./HeroSection.astro";
import ResortSection from "./ResortSection.astro";
import ListingsSection from "./ListingsSection.astro";
import ServicesSection from "./ServicesSection.astro";
import ActivitiesSection from "./ActivitiesSection.astro";
import ReviewsSection from "./ReviewsSection.astro";
import ContactSection from "@components/contact/ContactSection.astro";
import BlogSection from "./BlogSection.astro";

interface Props {
  lang: Locale;
  reviews: Review[];
}

const { lang, reviews } = Astro.props;
---

<HeroSection {lang} />
<ResortSection {lang} />
<ListingsSection {lang} />
<ServicesSection {lang} />
<ActivitiesSection {lang} />
<ReviewsSection {lang} {reviews} />
<ContactSection {lang} sourceName="Home Page" />
<BlogSection {lang} />
