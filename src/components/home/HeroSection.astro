---
import { getImage } from "astro:assets";
import { localePrefix } from "@i18n/utils";
import { DEFAULT_LOCALE } from "@i18n/config";
import type { Locale } from "@i18n/config";
import type { HomePageData } from "@lib/types";
import desktopSrc from "@assets/Parque_Albatros.webp";
import mobileSrc from "@assets/Parque_Albatros-mob.webp";
import SectionHeading from "@components/ui/SectionHeading.astro";
import ResponsivePicture from "@components/ui/ResponsivePicture.astro";

interface Props {
  lang?: Locale;
  home?: HomePageData | null;
}

const { lang = DEFAULT_LOCALE, home } = Astro.props;

const [desktop, mobile] = await Promise.all([
  getImage({
    src: desktopSrc,
    widths: [1024, 1440, 1920],
    sizes: "100vw",
    format: "avif",
  }),
  getImage({
    src: mobileSrc,
    widths: [390, 640, 828],
    sizes: "100vw",
    format: "avif",
    quality: 45,
  }),
]);

const prefix = localePrefix(lang);
const btn1Href = home?.heroBtn1Href ? `${prefix}/${home.heroBtn1Href}` : `${prefix}/listings`;
const btn2Href = home?.heroBtn2Href ? `${prefix}/${home.heroBtn2Href}` : `${prefix}/sell-property`;
---

<link rel="preload" as="image" imagesrcset={mobile.srcSet.attribute} imagesizes="100vw" />

<section id="hero" class="section relative min-h-svh 2xl:min-h-240">
  <div class="flex flex-col items-center justify-center">
    <SectionHeading
      title={home?.heroTitle ?? "Albatros Tenerife"}
      subtitle={home?.heroSubtitle ?? ""}
      level={1}
      big
      subtitleClass="text-inherit"
    />

    <div
      class="w-full justify-center flex flex-wrap gap-4 [&>a]:btn [&>a]:btn-big [&>a]:border-white [&>a]:hover:bg-accent/80 [&>a]:hover:border-accent/60"
    >
      <a href={btn1Href}>{home?.heroBtn1 ?? "Buyers"}</a>
      <a href={btn2Href}>{home?.heroBtn2 ?? "Sellers"}</a>
    </div>

    <ResponsivePicture
      {desktop}
      {mobile}
      width={mobileSrc.width}
      height={mobileSrc.height}
    />
  </div>
</section>
