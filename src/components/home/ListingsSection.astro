---
import { DEFAULT_LOCALE } from "@i18n/config";
import { localePrefix } from "@i18n/utils";
import type { Locale } from "@i18n/config";
import type { HomePageData } from "@lib/types";
import SectionHeading from "@components/ui/SectionHeading.astro";
import PropertyList from "@components/listings/PropertyList.astro";
import { getProperties, getListingsSlugs } from "@lib/queries";

interface Props {
  lang?: Locale;
  home?: HomePageData | null;
  class?: string;
}

const { lang = DEFAULT_LOCALE, home } = Astro.props;

const [properties, listingsSlugs] = await Promise.all([
  getProperties(lang, 6),
  getListingsSlugs(),
]);

const listingsSlug = listingsSlugs[lang] ?? "listings";
const listingsHref = `${localePrefix(lang)}/${listingsSlug}`;
---

<section id="listings" class="section bg-gray-100">
  <div>
    <SectionHeading
      title={home?.listingsTitle ?? ""}
      subtitle={home?.listingsSubtitle ?? ""}
    />

    <PropertyList {properties} {lang} {listingsSlug} class="mb-10" />

    <a href={listingsHref} class="btn btn-outline mx-auto">
      {home?.listingsViewAll ?? ""}
    </a>
  </div>
</section>
