---
import { DEFAULT_LOCALE } from "@i18n/config";
import type { Locale } from "@i18n/config";
import type { HomePageData } from "@lib/types";
import { getPosts, getBlogSlugs } from "@lib/queries";
import { localePrefix } from "@i18n/utils";

import SectionHeading from "@components/ui/SectionHeading.astro";
import BlogList from "@components/blog/BlogList.astro";

interface Props {
  lang?: Locale;
  home?: HomePageData | null;
}

const { lang = DEFAULT_LOCALE, home } = Astro.props;

const [posts, blogSlugs] = await Promise.all([
  getPosts(lang, 3),
  getBlogSlugs(),
]);
const blogSlug = blogSlugs[lang] ?? "blog";

const blogHref = `${localePrefix(lang)}/${blogSlug}`;
---

<section id="blog" class="section bg-gray-100">
  <div>
    <SectionHeading
      title={home?.blogTitle ?? ""}
      subtitle={home?.blogSubtitle ?? ""}
    />

    <BlogList {posts} {lang} {blogSlug} class="mb-10" />

    <a href={blogHref} class="btn btn-outline mx-auto">{home?.blogViewAll ?? ""}</a>
  </div>
</section>
