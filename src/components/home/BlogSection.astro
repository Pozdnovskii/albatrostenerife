---
import { t } from "@i18n/ui";
import { DEFAULT_LOCALE } from "@i18n/config";
import type { Locale } from "@i18n/config";
import { getPosts, getBlogSlugs } from "@lib/queries";
import { localePrefix } from "@i18n/utils";

import SectionHeading from "@components/ui/SectionHeading.astro";
import BlogList from "@components/blog/BlogList.astro";

interface Props {
  lang?: Locale;
}

const { lang = DEFAULT_LOCALE } = Astro.props;

const [posts, blogSlugs] = await Promise.all([
  getPosts(lang, 3),
  getBlogSlugs(),
]);
const blogSlug = blogSlugs[lang] ?? "blog";

const blogHref = `${localePrefix(lang)}/${blogSlug}`;
---

<section id="blog" class="section bg-gray-100">
  <div>
    <SectionHeading
      title={t(lang, "blog.title")}
      subtitle={t(lang, "blog.subtitle")}
    />

    <BlogList {posts} {lang} {blogSlug} class="mb-10" />

    <a href={blogHref} class="btn btn-outline mx-auto"> View All Posts </a>
  </div>
</section>
