---
import Layout from "@layouts/Layout.astro";
import BlogPage from "@components/blog/BlogPage.astro";
import SchemaOrg from "@components/seo/SchemaOrg.astro";
import { LOCALES, DEFAULT_LOCALE } from "@i18n/config";
import type { Locale } from "@i18n/config";
import { localePrefix } from "@i18n/utils";
import { getTagPaths, getBlogSlugs, getBlogTexts } from "@lib/queries";
import { buildBreadcrumb } from "@lib/schema";

export async function getStaticPaths() {
  const [tags, blogSlugs] = await Promise.all([getTagPaths(), getBlogSlugs()]);
  const nonEnLangs = LOCALES.filter((l) => l !== DEFAULT_LOCALE);

  return tags.flatMap((tag) =>
    nonEnLangs.map((lang) => ({
      params: {
        lang,
        blogSlug: blogSlugs[lang] ?? "blog",
        slug: tag.slugs[lang] ?? tag.slugs[DEFAULT_LOCALE]!,
      },
      props: {
        tagId: tag._id,
        tagNames: tag.names,
        tagSlugs: tag.slugs,
        tagMetaTitles: tag.metaTitles,
        tagMetaDescriptions: tag.metaDescriptions,
        blogSlugs,
      },
    })),
  );
}

const { lang, blogSlug, slug } = Astro.params as {
  lang: Locale;
  blogSlug: string;
  slug: string;
};
const {
  tagId,
  tagNames,
  tagSlugs,
  tagMetaTitles,
  tagMetaDescriptions,
  blogSlugs,
} = Astro.props as {
  tagId: string;
  tagNames: Partial<Record<Locale, string>>;
  tagSlugs: Partial<Record<Locale, string>>;
  tagMetaTitles: Partial<Record<Locale, string>>;
  tagMetaDescriptions: Partial<Record<Locale, string>>;
  blogSlugs: Partial<Record<Locale, string>>;
};

const tagName = tagNames[lang] ?? tagNames[DEFAULT_LOCALE] ?? slug;
const metaTitle =
  tagMetaTitles?.[lang] ?? tagMetaTitles?.[DEFAULT_LOCALE] ?? tagName;
const metaDescription =
  tagMetaDescriptions?.[lang] ?? tagMetaDescriptions?.[DEFAULT_LOCALE] ?? "";

const blogTexts = await getBlogTexts(lang);
const origin = Astro.url.origin;
const blogUrl = `${origin}${localePrefix(lang)}/${blogSlug}`;
const pageUrl = String(Astro.url);
const breadcrumbSchema = buildBreadcrumb(
  [
    { name: "Home", url: origin + "/" },
    { name: blogTexts?.pageTitle ?? "Blog", url: blogUrl },
    { name: tagName, url: pageUrl },
  ],
  `${pageUrl}#breadcrumb`,
);

const alternateUrls = Object.fromEntries(
  LOCALES.map((l) => {
    const bs = blogSlugs[l] ?? blogSlugs[DEFAULT_LOCALE] ?? "blog";
    const ts = tagSlugs[l] ?? tagSlugs[DEFAULT_LOCALE] ?? slug;
    return [l, `${origin}${localePrefix(l)}/${bs}/tag/${ts}`];
  }),
) as Record<Locale, string>;
---

<Layout title={metaTitle} description={metaDescription} {lang} {alternateUrls}>
  <SchemaOrg schema={{ "@graph": [breadcrumbSchema] }} />
  <BlogPage {lang} {tagId} title={tagName} />
</Layout>
