---
import Layout from "@layouts/Layout.astro";
import BlogPage from "@components/blog/BlogPage.astro";
import { DEFAULT_LOCALE, LOCALES } from "@i18n/config";
import type { Locale } from "@i18n/config";
import { t } from "@i18n/ui";
import { localePrefix } from "@i18n/utils";
import { getTagPaths, getBlogSlugs } from "@lib/queries";

export async function getStaticPaths() {
  const [tags, blogSlugs] = await Promise.all([getTagPaths(), getBlogSlugs()]);
  return tags.map((tag) => ({
    params: { slug: tag.slugs[DEFAULT_LOCALE]! },
    props: {
      tagId: tag._id,
      tagNames: tag.names,
      tagSlugs: tag.slugs,
      tagMetaTitles: tag.metaTitles,
      tagMetaDescriptions: tag.metaDescriptions,
      blogSlugs,
    },
  }));
}

const lang = DEFAULT_LOCALE;
const { slug } = Astro.params as { slug: string };
const {
  tagId,
  tagNames,
  tagSlugs,
  tagMetaTitles,
  tagMetaDescriptions,
  blogSlugs,
} = Astro.props as {
  tagId: string;
  tagNames: Partial<Record<Locale, string>>;
  tagSlugs: Partial<Record<Locale, string>>;
  tagMetaTitles: Partial<Record<Locale, string>>;
  tagMetaDescriptions: Partial<Record<Locale, string>>;
  blogSlugs: Partial<Record<Locale, string>>;
};

const tagName = tagNames[lang] ?? tagNames.en ?? slug;
const metaTitle = tagMetaTitles?.[lang] ?? tagMetaTitles?.en ?? tagName;
const metaDescription =
  tagMetaDescriptions?.[lang] ?? tagMetaDescriptions?.en ?? "";

const origin = Astro.url.origin;
const blogSlug = blogSlugs[lang] ?? "blog";
const blogUrl = `${origin}/${blogSlug}`;

const alternateUrls = Object.fromEntries(
  LOCALES.map((l) => {
    const bs = blogSlugs[l] ?? blogSlugs[DEFAULT_LOCALE] ?? "blog";
    const ts = tagSlugs[l] ?? tagSlugs[DEFAULT_LOCALE] ?? slug;
    return [l, `${origin}${localePrefix(l)}/${bs}/tag/${ts}`];
  }),
) as Record<Locale, string>;
---

<Layout title={metaTitle} description={metaDescription} {lang} {alternateUrls}>
  <BlogPage {lang} {tagId} title={tagName} />
</Layout>
