---
import Layout from "@layouts/Layout.astro";
import BlogPage from "@components/blog/BlogPage.astro";
import { DEFAULT_LOCALE } from "@i18n/config";
import { buildAlternateUrls } from "@i18n/utils";
import {
  getPageContent,
  getBlogSlugs,
  getBlogTexts,
  sanityOgImage,
} from "@lib/queries";

const lang = DEFAULT_LOCALE;

const [seo, blogSlugs, blogTexts] = await Promise.all([
  getPageContent(lang, "blog"),
  getBlogSlugs(),
  getBlogTexts(lang),
]);

const alternateUrls = buildAlternateUrls(Astro.url.origin, blogSlugs);
---

<Layout
  title={seo?.metaTitle ?? blogTexts?.pageTitle ?? ""}
  description={seo?.metaDescription ?? blogTexts?.pageSubtitle ?? ""}
  {lang}
  {alternateUrls}
  ogImage={sanityOgImage(seo?.ogImageUrl)}
>
  <BlogPage {lang} />
</Layout>
