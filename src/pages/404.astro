---
import Layout from "@layouts/Layout.astro";
import SectionHeading from "@components/ui/SectionHeading.astro";

---

<Layout title="404 — Page Not Found" description="Sorry, the page you're looking for doesn't exist or may have been moved.">
  <section class="flex min-h-[70vh] flex-col items-center justify-center px-4">
    <p class="mb-4 text-8xl font-bold leading-none text-accent">404</p>
    <SectionHeading
      title="Page Not Found"
      subtitle="Sorry, the page you're looking for doesn't exist or may have been moved. Let's get you back on track."
      subtitleClass="text-white/50"
      level={1}
      smallMargin
    />
    <a
      href="/"
      class="inline-block rounded-full bg-accent px-8 py-3 font-medium text-black transition-opacity hover:opacity-80"
    >
      Back to Homepage
    </a>
  </section>
</Layout>
