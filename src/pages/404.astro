---
import Layout from "@layouts/Layout.astro";
import SectionHeading from "@components/ui/SectionHeading.astro";
import { getLangFromUrl, localePrefix } from "@i18n/utils";
import { getNotFoundTexts } from "@lib/queries";

export const prerender = true;

const lang = getLangFromUrl(Astro.url);
const homeUrl = `${localePrefix(lang)}/`;
const notFound = await getNotFoundTexts(lang);
---

<Layout
  title={`404 — ${notFound?.title ?? ""}`}
  description={notFound?.subtitle ?? ""}
  {lang}
>
  <section class="flex min-h-[70vh] flex-col items-center justify-center px-4">
    <p class="mb-4 text-8xl font-bold leading-none text-accent">404</p>
    <SectionHeading
      title={notFound?.title ?? ""}
      subtitle={notFound?.subtitle ?? ""}
      subtitleClass="text-white/50"
      level={1}
      smallMargin
    />
    <a
      href={homeUrl}
      class="inline-block rounded-full bg-accent px-8 py-3 font-medium text-black transition-opacity hover:opacity-80"
    >
      {notFound?.back ?? ""}
    </a>
  </section>
</Layout>
