---
import Layout from "@layouts/Layout.astro";
import { buildAlternateUrls } from "@i18n/utils";
import { DEFAULT_LOCALE } from "@i18n/config";
import {
  getAllPaths,
  getPageContent,
  getServicePageData,
  getServices,
  getLegalPageData,
  sanityOgImage,
} from "@lib/queries";
import { contactSchema } from "@lib/schema";
import SchemaOrg from "@components/seo/SchemaOrg.astro";
import type { UnifiedPath, ServiceCard } from "@lib/types";
import ServicePage from "@components/service/ServicePage.astro";
import LegalPage from "@components/legal/LegalPage.astro";
import ContactSection from "@components/contact/ContactSection.astro";
import SellersPage from "@components/contact/SellersPage.astro";

export async function getStaticPaths() {
  const paths = await getAllPaths();
  return paths
    .filter((p) => p.type !== "property" && p.type !== "post")
    .map((p) => ({ params: { slug: p.enSlug }, props: p }));
}

const { type, enSlug, slugs } = Astro.props as UnifiedPath;
const lang = DEFAULT_LOCALE;
const alternateUrls = buildAlternateUrls(Astro.url.origin, slugs);

// One fetch per type — SEO fields go to Layout, the rest to the page component
let title = "";
let description = "";
let ogImage: string | undefined;
let serviceData = null;
let otherServices: ServiceCard[] = [];
let legalData = null;

if (type === "service") {
  const [data, allServices] = await Promise.all([
    getServicePageData(lang, enSlug),
    getServices(lang),
  ]);
  title = data?.metaTitle ?? data?.title ?? "";
  description = data?.metaDescription ?? "";
  serviceData = data;
  otherServices = allServices.filter(s => s.slug !== enSlug);
} else {
  const [seo, legal] = await Promise.all([
    getPageContent(lang, enSlug),
    getLegalPageData(lang, enSlug),
  ]);
  title = seo?.metaTitle ?? seo?.title ?? "";
  description = seo?.metaDescription ?? "";
  ogImage = sanityOgImage(seo?.ogImageUrl);
  legalData = legal;
}
---

<Layout {title} {description} {lang} {alternateUrls} {ogImage}>
  {
    type === "service" && serviceData && (
      <ServicePage service={serviceData} {lang} {otherServices} />
    )
  }
  {type === "page" && enSlug === "contact" && <SchemaOrg schema={contactSchema(String(Astro.url), lang)} />}
  {type === "page" && enSlug === "contact" && <ContactSection {lang} level={1} sourceName="Contact Page" />}
  {type === "page" && enSlug === "sell-property" && <SellersPage {lang} />}
  {type === "page" && enSlug !== "contact" && enSlug !== "sell-property" && legalData && <LegalPage data={legalData} />}
  {
    type === "page" && enSlug !== "contact" && enSlug !== "sell-property" && !legalData && (
      <section class="flex min-h-[60vh] items-center justify-center bg-black text-white">
        <p class="text-lg text-white/60">{title} — coming soon</p>
      </section>
    )
  }
</Layout>
